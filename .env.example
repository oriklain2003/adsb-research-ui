# API base URL — leave unset on Vercel (relative /api/ calls hit Vercel rewrites)
# Set for local dev if not using Vite proxy
# VITE_API_URL=http://localhost:8000

# WebSocket URL — MUST be set on Vercel (Vercel cannot proxy WebSockets)
# Points directly to the App Runner backend
# VITE_WS_URL=wss://your-app-runner-domain.awsapprunner.com/ws/live
